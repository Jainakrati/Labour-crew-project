rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, 'hirer' | 'worker' | 'admin')
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - skills: list (optional)
    //   - rating: number (optional)
    //   - reviewCount: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: jobs
    // Document ID: jobId
    // Fields:
    //   - hirerId: string (required)
    //   - title: string (required)
    //   - description: string (required)
    //   - location: string (required)
    //   - salary: number (required)
    //   - status: string (required, 'open' | 'closed' | 'completed')
    //   - createdAt: timestamp (required)
    //
    // Collection: applications
    // Document ID: applicationId
    // Fields:
    //   - jobId: string (required)
    //   - workerId: string (required)
    //   - hirerId: string (required)
    //   - status: string (required, 'pending' | 'accepted' | 'rejected')
    //   - createdAt: timestamp (required)
    //
    // Collection: bookings
    // Document ID: bookingId
    // Fields:
    //   - jobId: string (required)
    //   - workerId: string (required)
    //   - hirerId: string (required)
    //   - status: string (required, 'scheduled' | 'in-progress' | 'completed' | 'cancelled')
    //   - scheduledAt: timestamp (required)
    //   - completedAt: timestamp (optional)
    //
    // Collection: notifications
    // Document ID: notificationId
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - read: bool (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: reviews
    // Document ID: reviewId
    // Fields:
    //   - fromId: string (required)
    //   - toId: string (required)
    //   - bookingId: string (required)
    //   - rating: number (required)
    //   - comment: string (optional)
    //   - createdAt: timestamp (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "jainakrati30@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.role in ['hirer', 'worker', 'admin'];
    }

    function isValidUserPrivate(data) {
      return data.email is string;
    }

    function isValidJob(data) {
      return data.hirerId is string && 
             data.title is string && 
             data.status in ['open', 'closed', 'completed'];
    }

    function isValidApplication(data) {
      return data.jobId is string &&
             data.workerId is string &&
             data.hirerId is string &&
             data.status in ['pending', 'accepted', 'rejected'];
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['jobId', 'workerId', 'hirerId', 'status', 'scheduledAt']) &&
             data.jobId is string &&
             data.workerId is string &&
             data.hirerId is string &&
             data.status in ['scheduled', 'in-progress', 'completed', 'cancelled'] &&
             data.scheduledAt is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.read is bool &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['fromId', 'toId', 'bookingId', 'rating', 'createdAt']) &&
             data.fromId is string && (data.fromId == request.auth.uid || isAdmin()) &&
             data.toId is string &&
             data.bookingId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt is timestamp &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());

      match /private/profile {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidUserPrivate(request.resource.data);
      }
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.hirerId == request.auth.uid || isAdmin()) && isValidJob(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.hirerId == request.auth.uid || isAdmin());
    }

    match /applications/{applicationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidApplication(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.workerId == request.auth.uid || resource.data.hirerId == request.auth.uid || isAdmin()) && isValidApplication(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.workerId == request.auth.uid || isAdmin());
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.workerId == request.auth.uid || resource.data.hirerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.hirerId == request.auth.uid || isAdmin()) && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.workerId == request.auth.uid || resource.data.hirerId == request.auth.uid || isAdmin()) && isValidBooking(request.resource.data);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidNotification(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.fromId == request.auth.uid || isAdmin()) && isValidReview(request.resource.data);
    }
  }
}
